  <name>spring-agent-core</name>
  <description>Core agent framework: stateful conversations, tool execution, agent loop, events, compaction</description>
  <url>https://github.com/NewWaveAI/spring-agent/spring-agent-core</url>
  <licenses>
    <license>
      <name>Apache License, Version 2.0</name>
      <url>https://www.apache.org/licenses/LICENSE-2.0</url>
    </license>
  </licenses>
  <developers>
    <developer>
      <name>NewWave AI</name>
      <organization>NewWave AI</organization>
      <organizationUrl>https://new-wave.ai</organizationUrl>
